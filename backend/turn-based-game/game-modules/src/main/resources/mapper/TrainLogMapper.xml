<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cn.iocoder.gamemodules.mapper.TrainLogMapper">

    <select id="selectByTrainId" resultType="cn.iocoder.gamemodules.entity.TrainLog">
        SELECT id, train_id, user_id, round, log_text, create_time
        FROM train_log
        WHERE train_id = #{trainId}
        ORDER BY id ASC
    </select>

</mapper>
