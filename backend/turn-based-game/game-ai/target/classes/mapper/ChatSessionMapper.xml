<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cn.iocoder.gameai.mapper.ChatSessionMapper">
    
    <!-- 根据用户ID查询未删除的会话列表 -->
    <select id="selectByUserId" resultType="cn.iocoder.gameai.entity.ChatSession">
        SELECT * FROM chat_session
        WHERE user_id = #{userId}
        AND is_deleted = 0
        ORDER BY update_time DESC
    </select>
    
    <!-- 根据会话ID和用户ID查询会话 -->
    <select id="selectByIdAndUserId" resultType="cn.iocoder.gameai.entity.ChatSession">
        SELECT * FROM chat_session
        WHERE id = #{id}
        AND user_id = #{userId}
        AND is_deleted = 0
    </select>
</mapper>